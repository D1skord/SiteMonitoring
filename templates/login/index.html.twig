{% extends 'empty.html.twig' %}

{% block title %}Вход | Site monitoring{% endblock %}
{% block body_class %}auth-page login-page{% endblock %}

{% block body %}
  <div class="auth-shell d-flex align-items-center justify-content-center py-5">
    <div class="auth-panel w-100">
      <div class="text-center mb-4">
        <div class="auth-brand-icon mx-auto mb-3">
          <i class="fa-solid fa-chart-line"></i>
        </div>
        <h1 class="h3 mb-2">Site monitoring</h1>
        <div class="text-muted">Войдите, чтобы управлять проверками сайтов</div>
      </div>

      <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-md-5">
          {% if error %}
            <div class="alert alert-danger" role="alert">
              {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
          {% endif %}

          <form action="{{ path('app_login') }}" method="post">
            <div class="form-floating mb-3">
              <input class="form-control" id="inputEmail" type="email" placeholder="name@example.com" name="_username" value="{{ last_username }}" autocomplete="email" required autofocus>
              <label for="inputEmail">Email</label>
            </div>
            <div class="form-floating mb-4">
              <input class="form-control" id="inputPassword" type="password" name="_password" placeholder="Пароль" autocomplete="current-password" required>
              <label for="inputPassword">Пароль</label>
            </div>
            <button class="btn btn-primary w-100 py-2" type="submit">
              <i class="fa-solid fa-right-to-bracket me-1"></i>
              Войти
            </button>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
          </form>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
