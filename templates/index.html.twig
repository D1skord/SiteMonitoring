{% extends 'base.html.twig' %}

{% block title %}Главная{% endblock %}

{% block body %}
  {% set totalSites = sites|length %}
  {% set onlineSites = sites|filter(site => site.status == 200)|length %}
  {% set problemCount = problemSites|length %}

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mt-4 mb-4">
    <div>
      <h1 class="mb-1">Обзор мониторинга</h1>
      <div class="text-muted">Текущее состояние сайтов, последние проверки и зоны внимания</div>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <a class="btn btn-light" href="{{ path('sites_index') }}">
        <i class="fa-solid fa-list me-1"></i>
        Все сайты
      </a>
      <a class="btn btn-primary" href="{{ path('sites_new') }}">
        <i class="fa-solid fa-plus me-1"></i>
        Добавить сайт
      </a>
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-xl-3 col-md-6">
      <div class="card border-start border-primary border-4 mb-3">
        <div class="card-body">
          <div class="small text-muted text-uppercase">Всего сайтов</div>
          <div class="h3 mb-0">{{ totalSites }}</div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card border-start border-success border-4 mb-3">
        <div class="card-body">
          <div class="small text-muted text-uppercase">Онлайн</div>
          <div class="h3 mb-0">{{ onlineSites }}</div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card border-start border-danger border-4 mb-3">
        <div class="card-body">
          <div class="small text-muted text-uppercase">Проблемы</div>
          <div class="h3 mb-0">{{ problemCount }}</div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card border-start border-warning border-4 mb-3">
        <div class="card-body">
          <div class="small text-muted text-uppercase">Истекает скоро</div>
          <div class="h3 mb-0">{{ expiringSites|length }}</div>
        </div>
      </div>
    </div>
  </div>

  {% if totalSites == 0 %}
    <div class="card mb-4">
      <div class="card-body text-center py-5">
        <i class="fa-regular fa-folder-open d-block fs-1 text-muted mb-3"></i>
        <h2 class="h5">Сайтов пока нет</h2>
        <p class="text-muted mb-4">Добавьте первый сайт, чтобы начать мониторинг доступности, домена и SSL.</p>
        <a class="btn btn-primary" href="{{ path('sites_new') }}">
          <i class="fa-solid fa-plus me-1"></i>
          Добавить сайт
        </a>
      </div>
    </div>
  {% else %}
    <div class="row">
      <div class="col-xl-7">
        <div class="card mb-4">
          <div class="card-header">
            <i class="fa-solid fa-triangle-exclamation me-1"></i>
            Требуют внимания
          </div>
          <div class="card-body p-0">
            {% if attentionSites|length > 0 %}
              <div class="list-group list-group-flush">
                {% for site in attentionSites|slice(0, 8) %}
                  {% set expireDate = site.expireDate %}
                  {% set hasProblem = site.status is not null and site.status != 200 %}
                  {% set hasUnknownStatus = site.status is null %}
                  {% set domainExpires = expireDate and expireDate.domain and expireDate.domain <= expiresBefore %}
                  {% set sslExpires = expireDate and expireDate.ssl and expireDate.ssl <= expiresBefore %}
                  <a class="list-group-item list-group-item-action py-3" href="{{ path('sites_show', {'id': site.id}) }}">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                      <div class="min-width-0">
                        <div class="fw-semibold text-truncate">{{ site.name }}</div>
                        <div class="small text-muted text-truncate dashboard-url">{{ site.url }}</div>
                        <div class="d-flex flex-wrap gap-2 mt-2">
                          {% if hasProblem %}
                            <span class="badge bg-danger">HTTP {{ site.status }}</span>
                          {% endif %}
                          {% if hasUnknownStatus %}
                            <span class="badge bg-secondary">Нет статуса</span>
                          {% endif %}
                          {% if domainExpires %}
                            <span class="badge bg-warning text-dark">Домен {{ expireDate.domain|date('d.m.Y') }}</span>
                          {% endif %}
                          {% if sslExpires %}
                            <span class="badge bg-warning text-dark">SSL {{ expireDate.ssl|date('d.m.Y') }}</span>
                          {% endif %}
                        </div>
                      </div>
                      <i class="fa-solid fa-chevron-right text-muted mt-1"></i>
                    </div>
                  </a>
                {% endfor %}
              </div>
            {% else %}
              <div class="text-center text-muted py-5">
                <i class="fa-solid fa-circle-check fs-1 mb-3"></i>
                <div>Сейчас всё спокойно</div>
              </div>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="col-xl-5">
        <div class="card mb-4">
          <div class="card-header">
            <i class="fa-solid fa-clock-rotate-left me-1"></i>
            Последние проверки
          </div>
          <div class="card-body p-0">
            {% if latestStatusLogs|length > 0 %}
              <div class="list-group list-group-flush">
                {% for statusLog in latestStatusLogs %}
                  {% set logSite = statusLog.site %}
                  <a class="list-group-item list-group-item-action py-3" href="{{ path('sites_show', {'id': logSite.id}) }}">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                      <div class="min-width-0">
                        <div class="fw-semibold text-truncate">{{ logSite.name }}</div>
                        <div class="small text-muted">{{ statusLog.timestamp|date('d.m.Y H:i') }}</div>
                      </div>
                      {% if statusLog.status == 200 %}
                        <span class="badge bg-success">200</span>
                      {% else %}
                        <span class="badge bg-danger">{{ statusLog.status }}</span>
                      {% endif %}
                    </div>
                  </a>
                {% endfor %}
              </div>
            {% else %}
              <div class="text-center text-muted py-5">
                <i class="fa-solid fa-clock d-block fs-1 mb-3"></i>
                Проверок пока нет
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}
{% endblock %}
