{% extends 'base.html.twig' %}

{% block title %}Site index{% endblock %}

{% block body %}
    {% set totalSites = sites|length %}
    {% set onlineSites = sites|filter(site => site.status == 200)|length %}
    {% set problemSites = sites|filter(site => site.status is not null and site.status != 200)|length %}
    {% set unknownSites = sites|filter(site => site.status is null)|length %}

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mt-4 mb-4">
        <div>
            <h1 class="mb-1">Сайты</h1>
            <div class="text-muted">Мониторинг доступности, доменов и SSL-сертификатов</div>
        </div>
        <a class="btn btn-primary" href="{{ path('sites_new') }}">
            <i class="fa-solid fa-plus me-1"></i>
            Добавить сайт
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-start border-primary border-4 mb-3">
                <div class="card-body">
                    <div class="small text-muted text-uppercase">Всего сайтов</div>
                    <div class="h3 mb-0">{{ totalSites }}</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-start border-success border-4 mb-3">
                <div class="card-body">
                    <div class="small text-muted text-uppercase">Онлайн</div>
                    <div class="h3 mb-0">{{ onlineSites }}</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-start border-danger border-4 mb-3">
                <div class="card-body">
                    <div class="small text-muted text-uppercase">Проблемы</div>
                    <div class="h3 mb-0">{{ problemSites }}</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-start border-secondary border-4 mb-3">
                <div class="card-body">
                    <div class="small text-muted text-uppercase">Нет данных</div>
                    <div class="h3 mb-0">{{ unknownSites }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex align-items-center justify-content-between">
            <div>
                <i class="fa-solid fa-table-list me-1"></i>
                Список сайтов
            </div>
        </div>
        <div class="card-body">
            <table class="table table-hover align-middle mb-0" id="datatablesSimple">
                <thead>
                <tr>
                    <th>Сайт</th>
                    <th>Статус</th>
                    <th>Домен</th>
                    <th>SSL</th>
                    <th class="text-end">Действия</th>
                </tr>
                </thead>
                <tbody>
                {% for site in sites %}
                    {% set status = site.status %}
                    <tr>
                        <td>
                            <a class="fw-semibold text-decoration-none" href="{{ path('sites_show', {'id': site.id}) }}">{{ site.name }}</a>
                            <div class="small text-muted text-truncate site-url-cell">
                                <i class="fa-solid fa-link me-1"></i>
                                {{ site.url }}
                            </div>
                        </td>
                        <td>
                            {% if status == 200 %}
                                <span class="badge bg-success">200 Online</span>
                            {% elseif status is null %}
                                <span class="badge bg-secondary">Нет данных</span>
                            {% else %}
                                <span class="badge bg-danger">{{ status }} Ошибка</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if site.expireDate and site.expireDate.domain %}
                                {{ site.expireDate.domain|date("d.m.Y") }}
                            {% else %}
                                <span class="text-muted">Не проверялся</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if site.expireDate and site.expireDate.ssl %}
                                {{ site.expireDate.ssl|date("d.m.Y") }}
                            {% else %}
                                <span class="text-muted">Не проверялся</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group" aria-label="Действия с сайтом">
                                <a class="btn btn-outline-secondary" href="{{ path('sites_show', {'id': site.id}) }}" title="Открыть карточку">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a class="btn btn-outline-secondary" target="_blank" rel="noopener" href="{{ site.url }}" title="Открыть сайт">
                                    <i class="fa-solid fa-arrow-up-right-from-square"></i>
                                </a>
                                <a class="btn btn-outline-primary" href="{{ path('sites_edit', {'id': site.id}) }}" title="Редактировать">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            <i class="fa-regular fa-folder-open d-block mb-2 fs-2"></i>
                            Список пуст
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
