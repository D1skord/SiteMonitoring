{% extends 'base.html.twig' %}
{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block title %}New Site{% endblock %}

{% block body %}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mt-4 mb-4">
        <div>
            <h1 class="mb-1">Новый сайт</h1>
            <div class="text-muted">Добавьте URL, который нужно регулярно проверять</div>
        </div>
        <a class="btn btn-light" href="{{ path('sites_index') }}">
            <i class="fa-solid fa-arrow-left me-1"></i>
            Назад
        </a>
    </div>

    {{ include('site/_form.html.twig') }}
{% endblock %}
