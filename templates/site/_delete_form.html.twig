<form method="post" class="{{ compact|default(false) ? 'm-0' : 'mt-3' }}" action="{{ path('sites_delete', {'id': site.id}) }}" onsubmit="return confirm('Удалить этот сайт?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ site.id) }}">
    <button class="btn btn-danger">
        <i class="fa-solid fa-trash-can me-1"></i>
        Удалить
    </button>
</form>
