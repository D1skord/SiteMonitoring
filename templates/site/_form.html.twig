{{ form_start(form, {'attr': {'class': 'site-form'}}) }}
    <div class="card mb-4">
        <div class="card-header">
            <i class="fa-solid fa-globe me-1"></i>
            Основные параметры
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    {{ form_row(form.name) }}
                </div>
                <div class="col-md-6">
                    {{ form_row(form.url) }}
                </div>
                <div class="col-12">
                    <div class="border rounded p-3">
                        {{ form_row(form.transport) }}
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-white d-flex flex-column flex-sm-row justify-content-end gap-2">
            <a class="btn btn-light" href="{{ cancel_path|default(path('sites_index')) }}">
                <i class="fa-solid fa-xmark me-1"></i>
                Отмена
            </a>
            <button class="btn btn-primary">
                <i class="fa-solid fa-floppy-disk me-1"></i>
                {{ button_label|default('Сохранить') }}
            </button>
        </div>
    </div>
{{ form_end(form) }}
