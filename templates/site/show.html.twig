{% extends 'base.html.twig' %}

{% block title %}Site{% endblock %}

{% block body %}
    <h1>Site</h1>

    <table class="table">
        <tbody>
        <tr>
            <th>Имя</th>
            <td>{{ site.name }}</td>
        </tr>
        <tr>
            <th>Ссылка</th>
            <td>{{ site.url }}</td>
        </tr>
        <tr>
            <th>Статус</th>
            <td>{{ site.status }}</td>
        </tr>


        <td>{{ site.expireDate ? site.expireDate.ssl|date("d.m.Y")|default(null) }}</td>

        <tr>
            <th>Дата оплаты</th>
            <td>{{ site.paymentInfo ? site.paymentInfo.paymentDate|date("d.m.Y")|default(null) }}</td>
        </tr>

        <tr>
            <th>Сумма</th>
            <td>{{ site.paymentInfo ? site.paymentInfo.cost|default(null) }}</td>
        </tr>

        <tr>
            <th>Дата окончания домена</th>
            <td>{{ site.expireDate ? site.expireDate.domain|date("d.m.Y")|default(null) }}</td>
        </tr>

        <tr>
            <th>Дата окончания SSL-сертификата</th>
            <td>{{ site.expireDate ? site.expireDate.ssl|date("d.m.Y")|default(null) }}</td>
        </tr>

        </tbody>
    </table>

    <a class="btn btn btn-light" href="{{ path('sites_index') }}">Назад</a>

    <a class="btn btn-warning" href="{{ path('sites_edit', {'id': site.id}) }}">Редактировать</a>

    {{ include('site/_delete_form.html.twig') }}
{% endblock %}
