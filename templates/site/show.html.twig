{% extends 'base.html.twig' %}

{% block title %}Site{% endblock %}

{% block body %}
    {% set status = site.status %}
    {% set hasChartData = statusChartData|length > 0 %}
    {% set hasResponseTimeChartData = responseTimeChartData|filter(responseTime => responseTime is not null)|length > 0 %}

    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3 mt-4 mb-4">
        <div>
            <div class="d-flex align-items-center gap-2 mb-2">
                <h1 class="mb-0">{{ site.name }}</h1>
                {% if status == 200 %}
                    <span class="badge bg-success">Online</span>
                {% elseif status is null %}
                    <span class="badge bg-secondary">Нет данных</span>
                {% else %}
                    <span class="badge bg-danger">Ошибка</span>
                {% endif %}
            </div>
            <a class="text-muted text-decoration-none" target="_blank" rel="noopener" href="{{ site.url }}">
                <i class="fa-solid fa-arrow-up-right-from-square me-1"></i>
                {{ site.url }}
            </a>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-light" href="{{ path('sites_index') }}">
                <i class="fa-solid fa-arrow-left me-1"></i>
                Назад
            </a>
            <a class="btn btn-outline-primary" target="_blank" rel="noopener" href="{{ site.url }}">
                <i class="fa-solid fa-arrow-up-right-from-square me-1"></i>
                Открыть сайт
            </a>
            <a class="btn btn-warning" href="{{ path('sites_edit', {'id': site.id}) }}">
                <i class="fa-solid fa-pen-to-square me-1"></i>
                Редактировать
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-start {{ status == 200 ? 'border-success' : (status is null ? 'border-secondary' : 'border-danger') }} border-4 mb-3">
                <div class="card-body">
                    <div class="small text-muted text-uppercase">HTTP статус</div>
                    <div class="h3 mb-0">{{ status ?? '-' }}</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-start border-primary border-4 mb-3">
                <div class="card-body">
                    <div class="small text-muted text-uppercase">Домен</div>
                    <div class="h5 mb-0">{{ site.expireDate and site.expireDate.domain ? site.expireDate.domain|date("d.m.Y") : 'Нет данных' }}</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-start border-info border-4 mb-3">
                <div class="card-body">
                    <div class="small text-muted text-uppercase">SSL</div>
                    <div class="h5 mb-0">{{ site.expireDate and site.expireDate.ssl ? site.expireDate.ssl|date("d.m.Y") : 'Нет данных' }}</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-start border-secondary border-4 mb-3">
                <div class="card-body">
                    <div class="small text-muted text-uppercase">Точек графика</div>
                    <div class="h3 mb-0">{{ statusChartData|length }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <div class="card h-100">
                <div class="card-header">
                    <i class="fas fa-chart-area me-1"></i>
                    Статусы за последние 24 часа
                </div>
                <div class="card-body" style="height: 320px;">
                    {% if hasChartData %}
                        <canvas id="siteStatusChart" width="100%" height="40"></canvas>
                    {% else %}
                        <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                            <i class="fa-solid fa-chart-line fs-1 mb-3"></i>
                            <div>Пока нет данных для графика</div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header">
                    <i class="fa-solid fa-stopwatch me-1"></i>
                    Response time за последние 24 часа
                </div>
                <div class="card-body" style="height: 320px;">
                    {% if hasResponseTimeChartData %}
                        <canvas id="siteResponseTimeChart" width="100%" height="40"></canvas>
                    {% else %}
                        <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                            <i class="fa-solid fa-chart-line fs-1 mb-3"></i>
                            <div>Пока нет данных для графика</div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <i class="fa-solid fa-circle-info me-1"></i>
            Параметры сайта
        </div>
        <div class="card-body">
            <dl class="row mb-0 site-details-list">
                <dt class="col-sm-4">Название</dt>
                <dd class="col-sm-8">{{ site.name }}</dd>
                <dt class="col-sm-4">Ссылка</dt>
                <dd class="col-sm-8">
                    <a target="_blank" rel="noopener" href="{{ site.url }}">{{ site.url }}</a>
                </dd>
                <dt class="col-sm-4">HTTP статус</dt>
                <dd class="col-sm-8">{{ status ?? 'Нет данных' }}</dd>
                <dt class="col-sm-4">Дата окончания домена</dt>
                <dd class="col-sm-8">{{ site.expireDate and site.expireDate.domain ? site.expireDate.domain|date("d.m.Y") : 'Нет данных' }}</dd>
                <dt class="col-sm-4">Дата окончания SSL-сертификата</dt>
                <dd class="col-sm-8">{{ site.expireDate and site.expireDate.ssl ? site.expireDate.ssl|date("d.m.Y") : 'Нет данных' }}</dd>
            </dl>
        </div>
    </div>

    <div class="mb-4">
        {{ include('site/_delete_form.html.twig') }}
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        const statusChartElement = document.getElementById('siteStatusChart');
        const responseTimeChartElement = document.getElementById('siteResponseTimeChart');
        const statusChartData = {{ statusChartData|json_encode|raw }};
        const responseTimeChartData = {{ responseTimeChartData|json_encode|raw }};
        const statusChartPointColors = statusChartData.map((status) => status === 200
            ? 'rgba(25, 135, 84, 1)'
            : 'rgba(220, 53, 69, 1)'
        );

        if (statusChartElement) {
            new Chart(statusChartElement, {
                type: 'line',
                data: {
                    labels: {{ statusChartLabels|json_encode|raw }},
                    datasets: [{
                        label: 'HTTP статус',
                        data: statusChartData,
                        lineTension: 0.15,
                        backgroundColor: 'rgba(2, 117, 216, 0.15)',
                        borderColor: 'rgba(2, 117, 216, 1)',
                        pointRadius: 2,
                        pointBackgroundColor: statusChartPointColors,
                        pointBorderColor: 'rgba(255, 255, 255, 0.8)',
                        pointHoverRadius: 4,
                        pointHitRadius: 8,
                        pointBorderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        xAxes: [{
                            gridLines: {
                                display: false
                            },
                            ticks: {
                                maxTicksLimit: 12
                            }
                        }],
                        yAxes: [{
                            ticks: {
                                min: 0,
                                max: 600,
                                stepSize: 100
                            }
                        }]
                    },
                    legend: {
                        display: false
                    }
                }
            });
        }

        if (responseTimeChartElement) {
            new Chart(responseTimeChartElement, {
                type: 'line',
                data: {
                    labels: {{ statusChartLabels|json_encode|raw }},
                    datasets: [{
                        label: 'Response time, ms',
                        data: responseTimeChartData,
                        lineTension: 0.15,
                        backgroundColor: 'rgba(13, 110, 253, 0.15)',
                        borderColor: 'rgba(13, 110, 253, 1)',
                        pointRadius: 2,
                        pointBackgroundColor: 'rgba(13, 110, 253, 1)',
                        pointBorderColor: 'rgba(255, 255, 255, 0.8)',
                        pointHoverRadius: 4,
                        pointHitRadius: 8,
                        pointBorderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        xAxes: [{
                            gridLines: {
                                display: false
                            },
                            ticks: {
                                maxTicksLimit: 12
                            }
                        }],
                        yAxes: [{
                            ticks: {
                                min: 0,
                                callback: function (value) {
                                    return value + ' ms';
                                }
                            }
                        }]
                    },
                    legend: {
                        display: false
                    },
                    tooltips: {
                        callbacks: {
                            label: function (tooltipItem) {
                                return tooltipItem.yLabel + ' ms';
                            }
                        }
                    }
                }
            });
        }
    </script>
{% endblock %}
