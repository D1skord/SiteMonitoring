{% extends 'base.html.twig' %}

{% block title %}Site{% endblock %}

{% block body %}
    <h1>Site</h1>

    <table class="table">
        <tbody>
        <tr>
            <th>Имя</th>
            <td>{{ site.name }}</td>
        </tr>
        <tr>
            <th>Ссылка</th>
            <td>{{ site.url }}</td>
        </tr>
        <tr>
            <th>Статус</th>
            <td>{{ site.status }}</td>
        </tr>


        <td>{{ site.expireDate ? site.expireDate.ssl|date("d.m.Y")|default(null) }}</td>

        <tr>
            <th>Дата окончания домена</th>
            <td>{{ site.expireDate ? site.expireDate.domain|date("d.m.Y")|default(null) }}</td>
        </tr>

        <tr>
            <th>Дата окончания SSL-сертификата</th>
            <td>{{ site.expireDate ? site.expireDate.ssl|date("d.m.Y")|default(null) }}</td>
        </tr>

        </tbody>
    </table>

    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-chart-area me-1"></i>
            Статусы за последние 24 часа
        </div>
        <div class="card-body" style="height: 320px;">
            <canvas id="siteStatusChart" width="100%" height="40"></canvas>
        </div>
    </div>

    <a class="btn btn btn-light" href="{{ path('sites_index') }}">Назад</a>

    <a class="btn btn-warning" href="{{ path('sites_edit', {'id': site.id}) }}">Редактировать</a>

    {{ include('site/_delete_form.html.twig') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        const statusChartElement = document.getElementById('siteStatusChart');
        const statusChartData = {{ statusChartData|json_encode|raw }};
        const statusChartPointColors = statusChartData.map((status) => status === 200
            ? 'rgba(25, 135, 84, 1)'
            : 'rgba(220, 53, 69, 1)'
        );

        if (statusChartElement) {
            new Chart(statusChartElement, {
                type: 'line',
                data: {
                    labels: {{ statusChartLabels|json_encode|raw }},
                    datasets: [{
                        label: 'HTTP статус',
                        data: statusChartData,
                        lineTension: 0.15,
                        backgroundColor: 'rgba(2, 117, 216, 0.15)',
                        borderColor: 'rgba(2, 117, 216, 1)',
                        pointRadius: 2,
                        pointBackgroundColor: statusChartPointColors,
                        pointBorderColor: 'rgba(255, 255, 255, 0.8)',
                        pointHoverRadius: 4,
                        pointHitRadius: 8,
                        pointBorderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        xAxes: [{
                            gridLines: {
                                display: false
                            },
                            ticks: {
                                maxTicksLimit: 12
                            }
                        }],
                        yAxes: [{
                            ticks: {
                                min: 0,
                                max: 600,
                                stepSize: 100
                            }
                        }]
                    },
                    legend: {
                        display: false
                    }
                }
            });
        }
    </script>
{% endblock %}
