# Local development environment example.
# Copy this file to .env and change values for your machine.

UID=1000
GID=1000
PROJECT_FOLDER_NAME=sitemonitoring
TIMEZONE=Europe/Moscow

DOMAIN_NAME=site-monitoring.local
NGINX_PORT=80

POSTGRES_PORT=5433
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_VERSION=13
POSTGRES_DB=site_monitoring

RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_PASS=guest

PHPPGADMIN_PORT=5434

APP_ENV=dev
APP_SECRET=change-me
DATABASE_URL=postgres://app:change-me@postgres:5432/site_monitoring?serverVersion=13&charset=utf8
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@rabbitmq:5672/%2f/messages
TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_CHAT_ID=change-me
VK_BOT_TOKEN=change-me
VK_PEER_ID=change-me
VK_API_VERSION=5.199
