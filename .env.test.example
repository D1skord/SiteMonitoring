# Test environment example.
# Copy this file to .env.test when tests need local overrides.

UID=1000
GID=1000
PROJECT_FOLDER_NAME=sitemonitoring_test
TIMEZONE=Europe/Moscow

POSTGRES_USER=test
POSTGRES_PASSWORD=test
POSTGRES_VERSION=13
POSTGRES_DB=site_monitoring

APP_ENV=test
KERNEL_CLASS='App\Kernel'
APP_SECRET=change-me
SYMFONY_DEPRECATIONS_HELPER=999999
DATABASE_URL=postgres://test:test@postgres_test:5432/site_monitoring?serverVersion=13&charset=utf8
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@rabbitmq_test:5672/%2f/messages
TELEGRAM_BOT_TOKEN=test-token
TELEGRAM_CHAT_ID=test-chat-id
